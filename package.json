{
  "name": "localserve",
  "version": "0.1.0",
  "private": true,
  "description": "LocalServe MVP monorepo for QR-based hyperlocal vendor ordering.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @localserve/api",
    "dev:web": "npm run dev --workspace @localserve/web",
    "dev:api": "npm run dev --workspace @localserve/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
