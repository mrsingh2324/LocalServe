PORT=4000
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGIN=*
DEV_VENDOR_TOKEN=dev-vendor-token
JWT_SECRET=replace-with-a-long-random-secret
USE_MONGO=true
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/localserve?retryWrites=true&w=majority
MONGODB_URI=mongodb://localserve:localserve@localhost:27017/localserve?authSource=admin
REDIS_URL=redis://localhost:6379
RAZORPAY_WEBHOOK_SECRET=replace-in-production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PLATFORM_FEE_PERCENT=2
EMAIL_FROM=orders@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
OTP_DEV_CODE=123456
OTP_TTL_MINUTES=5
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=
# Platform admin console (required in production)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# Web push notifications (optional; generate with `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:orders@example.com
